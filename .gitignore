# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
prototypes

# playwright
/e2e-tests/test-results/
/e2e-tests/playwright-report/
/e2e-tests/playwright/.cache/

# next.js
/.next/
/out/
docs/.next/
docs/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files / allows .env.local_template to be tracked
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Swagger UI assets — vendored from `swagger-ui-dist` by
# scripts/copy-swagger-ui.ts (regenerated on predev / prebuild), not committed.
/public/swagger-ui/

# GSD / agent runtime (per-developer, regenerated on demand — not project code)
.gsd/
.agents/
.bg-shell/
skills-lock.json
.claude
.mcp.json

# Winston log output — runtime artefacts, never committed
.logs/

# pnpm local store — machine-specific cache
.pnpm-store/

# Diagram icons — generated at runtime by diagrams/main.py, not committed
diagrams/icons/

# Dev Containers lockfile — auto-generated, machine-specific
.devcontainer/devcontainer-lock.json
.ideas
